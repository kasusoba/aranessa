PUBLIC_LASTFM_API_KEY=your_api_key_here
PUBLIC_LASTFM_USERNAME=your_username_here
ANILIST_USERNAME=your_anilist_username_here
# PUBLIC_ so the live "now watching" poller can read them in the browser too.
# (Trakt client id + TMDB v3 key are read-only and safe to expose client-side.)
PUBLIC_TRAKT_CLIENT_ID=your_trakt_client_id_here
PUBLIC_TRAKT_USERNAME=your_trakt_username_here
PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
STEAM_API_KEY=your_steam_api_key_here
GH_USERNAME=your_github_username_here
GH_TOKEN=your_github_personal_access_token_here
HARDCOVER_TOKEN=your_hardcover_token_here