---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { userConfig } from "../config";
import { getProjects } from "../lib/github";

// Pull from GitHub at build time (repos tagged `portfolio`), falling back to
// the hardcoded list if the API is unavailable, unconfigured, or no repos are
// tagged yet.
const fetched = await getProjects();
const projects =
  fetched && fetched.length > 0
    ? fetched
    : userConfig.projects.map((p) => ({ ...p, featured: false }));

// Repos tagged `featured` get the big hero treatment; the rest fill the grid.
// If nothing is tagged, promote the top (most recently pushed) repo so there's
// always a hero.
let featured = projects.filter((p) => "featured" in p && p.featured);
let rest = projects.filter((p) => !("featured" in p && p.featured));
if (featured.length === 0 && projects.length > 0) {
  featured = [projects[0]];
  rest = projects.slice(1);
}

const imgOf = (image: string | { src: string } | null) =>
  image ? (typeof image === "string" ? image : image.src) : null;
---

<Layout>
  <div class="flex flex-col gap-9">
    <h1 class="font-medium text-primary tracking-wide">projects</h1>

    <!-- Heroes — every featured repo gets the big card -->
    <section class="flex flex-col gap-6">
      {
        featured.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noreferrer"
            class="group flex flex-col gap-4"
          >
            <div class="aspect-video w-full rounded-2xl overflow-hidden border border-white/5 bg-darkblue-200/50 flex items-center justify-center transition-colors group-hover:border-white/10">
              {imgOf(p.image) ? (
                <img
                  src={imgOf(p.image)}
                  alt={p.title}
                  loading="lazy"
                  class="w-full h-full object-contain opacity-90 group-hover:opacity-100 transition-opacity duration-500"
                />
              ) : (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary-opaque/20"
                >
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                  <line x1="3" y1="9" x2="21" y2="9" />
                  <line x1="9" y1="21" x2="9" y2="9" />
                </svg>
              )}
            </div>
            <div class="flex items-center gap-3">
              <h3 class="text-accent-blue font-medium text-xl">{p.title}</h3>
              <span class="shrink-0 text-xs lowercase text-accent-gold border border-primary-opaque/20 px-2 py-0.5 rounded-full">
                {p.category}
              </span>
            </div>
            <p class="text-sm text-primary-opaque/75 leading-relaxed max-w-2xl">
              {p.description}
            </p>
          </a>
        ))
      }
    </section>

    <!-- The rest — spacing alone separates them from the heroes -->
    {
      rest.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
          {rest.map((p) => (
            <ProjectCard project={p} />
          ))}
        </div>
      )
    }
  </div>
</Layout>
