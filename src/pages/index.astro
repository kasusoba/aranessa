---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import picProfile from "../assets/profile.jpeg";
import { getHomeData } from "../lib/home";
import { userConfig } from "../config";

const { quad, feed } = await getHomeData();
const rows = [quad.listening, quad.watching, quad.reading, quad.playing].filter(
  (r): r is NonNullable<typeof r> => r != null,
);
const project = userConfig.projects[0]; // the newest thing i'm building
---

<Layout>
  <div class="flex flex-col gap-8 min-h-full">
    <!-- Intro: making + voice lead; what i'm into is a quiet snapshot below -->
    <section class="flex flex-col gap-6">
      <Image src={picProfile} alt="" width={100} height={100} data-egg-trigger class="rounded-2xl w-24 h-24 object-cover opacity-90 select-none" />
      <div class="flex flex-col gap-4 max-w-md">
        <h1 class="text-primary text-lg group-wave">hey, i'm <span class="text-accent-blue font-medium">sal</span> <span class="wave">👋</span></h1>
        <p class="text-primary leading-relaxed">
          i make small web things. mostly i'm just curious, an empty vessel trying to
          fill up on whatever catches me. this little corner of the internet is where
          it spills out.
        </p>
        {
          project && (
            <p class="text-sm text-primary-opaque/50">
              lately building{" "}
              <a href={project.url} target="_blank" rel="noreferrer" class="text-primary-opaque/80 hover:text-accent-blue transition-colors">
                {project.title}
              </a>
            </p>
          )
        }
      </div>
    </section>

    <!-- currently — quiet inline lines; the now-playing one comes alive when live -->
    <section class="flex flex-col gap-4">
      <h2 class="text-sm font-medium text-primary-opaque/60 lowercase">currently</h2>
      <p class="text-primary leading-loose">
        {
          rows.map((r, idx) => {
            const isNp = quad.listening != null && r === quad.listening;
            return (
              <>
                {idx > 0 && <span class="text-primary-opaque/25"> · </span>}
                <a href={r.url} target="_blank" rel="noreferrer" class="group whitespace-nowrap" data-np={isNp ? "" : undefined}>
                  {isNp && <span data-np-dot class="hidden w-1.5 h-1.5 rounded-full bg-accent-gold animate-pulse align-middle mr-1.5 group-[.is-live]:inline-block" />}
                  {r.image && <img src={r.image} alt="" data-np-img={isNp ? "" : undefined} class="inline-block w-5 h-5 rounded object-cover align-middle mr-1.5 opacity-80 group-hover:opacity-100 transition-opacity" />}
                  <span data-np-label={isNp ? "" : undefined} class="text-primary-opaque/45 lowercase">{r.label} </span>
                  <span data-np-title={isNp ? "" : undefined} class="text-primary-opaque/90 group-hover:text-accent-blue transition-colors">{r.title}</span>
                </a>
              </>
            );
          })
        }
      </p>
    </section>

    <!-- lately — grayscale by default; only the curious hover to bring it to life -->
    <section class="flex flex-col gap-4">
      <h2 class="text-sm font-medium text-primary-opaque/60 lowercase">lately</h2>
      <div class="flex gap-2.5 overflow-x-auto pb-2 -mx-1 px-1">
        {
          feed.slice(0, 16).map((i) => (
            <a href={i.url} target="_blank" rel="noreferrer" title={i.title} class="shrink-0 w-12 group">
              <div class="aspect-square w-full rounded-md overflow-hidden border border-white/5 bg-darkblue-200/50 grayscale opacity-55 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300">
                {i.image && <img src={i.image} alt="" loading="lazy" class="w-full h-full object-cover" />}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- presence: the time's readable; where it's that time is not. wouldn't you like to know -->
    <footer class="mt-auto flex items-center gap-1.5 text-xs text-primary-opaque/40">
      <span data-clock>--:--</span>
      <span>in</span>
      <span class="blur-[3px] select-none">nosy</span>
    </footer>
  </div>

  <style>
    .wave { display: inline-block; transform-origin: 70% 70%; }
    .group-wave:hover .wave { animation: wave 1.1s ease-in-out; }
    @keyframes wave {
      0%, 100% { transform: rotate(0); }
      20% { transform: rotate(-16deg); }
      40% { transform: rotate(12deg); }
      60% { transform: rotate(-10deg); }
      80% { transform: rotate(8deg); }
    }
  </style>

  <script>
    // Live local clock (rendered, then blurred by css — inspect to read it).
    function tickClock() {
      const time = new Intl.DateTimeFormat("en-US", {
        hour: "numeric", minute: "2-digit", hour12: true, timeZone: "Asia/Jakarta",
      }).format(new Date()).toLowerCase();
      const clock = document.querySelector("[data-clock]");
      if (clock) clock.textContent = time;
    }
    tickClock();
    setInterval(tickClock, 30000);

    // Live now-playing: poll Last.fm and light up the "currently" listen item.
    const KEY = import.meta.env.PUBLIC_LASTFM_API_KEY;
    const USER = import.meta.env.PUBLIC_LASTFM_USERNAME;
    const np = document.querySelector<HTMLAnchorElement>("[data-np]");
    async function pollNowPlaying() {
      if (!np || !KEY || !USER) return;
      try {
        const res = await fetch(
          `https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${USER}&api_key=${KEY}&format=json&limit=1`,
        );
        const data = await res.json();
        const t = data?.recenttracks?.track?.[0];
        const live = t?.["@attr"]?.nowplaying === "true";
        const title = np.querySelector<HTMLElement>("[data-np-title]");
        const label = np.querySelector<HTMLElement>("[data-np-label]");
        const img = np.querySelector<HTMLImageElement>("[data-np-img]");
        np.classList.toggle("is-live", !!live);
        if (live && t) {
          if (title) { title.textContent = t.name; title.classList.add("text-gradient-animate"); }
          if (label) label.textContent = "now playing ";
          const art = t.image?.find((i: any) => i.size === "large")?.["#text"] || t.image?.[0]?.["#text"];
          if (img && art) img.src = art;
          if (t.url) np.href = t.url;
        } else if (title) {
          title.classList.remove("text-gradient-animate");
        }
      } catch {}
    }
    pollNowPlaying();
    setInterval(pollNowPlaying, 30000);
  </script>
</Layout>
