---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import picProfile from "../assets/profile.jpeg";
import { getHomeData } from "../lib/home";
import { userConfig } from "../config";

const { quad, feed } = await getHomeData();
const rows = [quad.listening, quad.watching, quad.reading, quad.playing].filter(
  (r): r is NonNullable<typeof r> => r != null,
);
---

<Layout>
  <div class="flex flex-col gap-8 min-h-full">
    <!-- Intro: making + voice lead; what i'm into is a quiet snapshot below -->
    <section class="flex flex-col gap-6">
      <Image src={picProfile} alt="" width={100} height={100} data-egg-trigger class="rounded-2xl w-24 h-24 object-cover opacity-90 select-none" />
      <div class="flex flex-col gap-4 max-w-md">
        <h1 class="text-primary text-lg group-wave">hey, i'm <span class="text-accent-blue font-medium">sal</span></h1>
        <p class="text-primary leading-relaxed">
          i make whatever. i play whatever. i listen to whatever. i watch whatever. i read whatever. i write whatever. i code whatever. i draw whatever. i share whatever.
        </p>
      </div>
    </section>

    <!-- currently — quiet inline lines; the now-playing one comes alive when live -->
    <section class="flex flex-col gap-4">
      <h2 class="text-sm font-medium text-primary-opaque/60 lowercase">currently</h2>
      <p class="text-primary leading-loose">
        {
          rows.map((r, idx) => {
            const isNp = quad.listening != null && r === quad.listening;
            const isNw = quad.watching != null && r === quad.watching;
            const live = isNp || isNw; // listening + watching both come alive
            return (
              <>
                {idx > 0 && <span class="text-primary-opaque/25"> · </span>}
                <a href={r.url} target="_blank" rel="noreferrer" class="group whitespace-nowrap" data-np={isNp ? "" : undefined} data-nw={isNw ? "" : undefined}>
                  {live && <span data-live-dot class="hidden w-1.5 h-1.5 rounded-full bg-accent-gold animate-pulse align-middle mr-1.5 group-[.is-live]:inline-block" />}
                  {r.image && <img src={r.image} alt="" data-live-img={live ? "" : undefined} class="inline-block w-5 h-5 rounded object-cover align-middle mr-1.5 opacity-80 group-hover:opacity-100 transition-opacity" />}
                  <span data-live-label={live ? "" : undefined} class="text-primary-opaque/45 lowercase">{r.label} </span>
                  <span data-live-title={live ? "" : undefined} class="text-primary-opaque/90 group-hover:text-accent-blue transition-colors">{r.title}</span>
                </a>
              </>
            );
          })
        }
      </p>
    </section>

    <!-- lately — grayscale by default; only the curious hover to bring it to life -->
    <section class="flex flex-col gap-4">
      <h2 class="text-sm font-medium text-primary-opaque/60 lowercase">lately</h2>
      <div class="flex gap-2.5 overflow-x-auto pb-2 -mx-1 px-1">
        {
          feed.slice(0, 16).map((i) => (
            <a href={i.url} target="_blank" rel="noreferrer" title={i.title} class="shrink-0 w-12 group">
              <div class="aspect-square w-full rounded-md overflow-hidden border border-white/5 bg-darkblue-200/50 grayscale opacity-55 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300">
                {i.image && <img src={i.image} alt="" loading="lazy" class="w-full h-full object-cover" />}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- presence: the time's readable; where it's that time is not. wouldn't you like to know -->
    <footer class="mt-auto flex items-center gap-1.5 text-xs text-primary-opaque/40">
      <span data-clock>--:--</span>
      <span>in</span>
      <span class="blur-[3px] select-none">nosy</span>
    </footer>
  </div>

  <script>
    // Live local clock (rendered, then blurred by css — inspect to read it).
    function tickClock() {
      const time = new Intl.DateTimeFormat("en-US", {
        hour: "numeric", minute: "2-digit", hour12: true, timeZone: "Asia/Jakarta",
      }).format(new Date()).toLowerCase();
      const clock = document.querySelector("[data-clock]");
      if (clock) clock.textContent = time;
    }
    tickClock();
    setInterval(tickClock, 30000);

    // Live "currently": light up the now-playing (Last.fm) and now-watching
    // (Trakt) lines whenever something is actually on.
    import { fetchTracks, fetchWatching, poll } from "../scripts/live";

    function paint(sel: string, live: boolean, label: string, title: string, url: string, image: string) {
      const el = document.querySelector<HTMLAnchorElement>(sel);
      if (!el) return;
      el.classList.toggle("is-live", live);
      const t = el.querySelector<HTMLElement>("[data-live-title]");
      const l = el.querySelector<HTMLElement>("[data-live-label]");
      const img = el.querySelector<HTMLImageElement>("[data-live-img]");
      if (live) {
        if (t) { t.textContent = title; t.classList.add("text-gradient-animate"); }
        if (l) l.textContent = `${label} `;
        if (img && image) img.src = image;
        if (url) el.href = url;
      } else if (t) {
        t.classList.remove("text-gradient-animate");
      }
    }

    poll(async () => {
      const tracks = await fetchTracks(1);
      if (!tracks) return;
      const np = tracks[0];
      paint("[data-np]", !!np?.live, "now playing", np?.name ?? "", np?.url ?? "", np?.image ?? "");
    }, 30000);

    poll(async () => {
      const w = await fetchWatching();
      if (!w) return;
      paint("[data-nw]", w.live, "now watching", w.title, w.url, w.image);
    }, 30000);
  </script>
</Layout>
