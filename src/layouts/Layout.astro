---
import "../styles/global.css";
import { userConfig } from "../config";
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isProjects = currentPath.startsWith("/projects");
const isListen = currentPath.startsWith("/listen");
const isWatch = currentPath.startsWith("/watch");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>onesal.me</title>
  </head>
  <body class="bg-darkblue-300 text-primary">
    <!-- Easter egg (Dorohedoro): clicking the home avatar travels into Kaiman's
         mouth (front→back) to reveal Risu behind the card, then a timed
         Netflix-style subtitle. PLACEHOLDER teeth / throat / figure SVG — swap
         the whole #egg-bg-doro for the real clip. -->
    <div
      id="egg-bg-doro"
      aria-hidden="true"
      class="fixed inset-0 z-0 opacity-0 pointer-events-none overflow-hidden"
    >
      <div class="egg-throat absolute inset-0"></div>
      <div id="egg-risu" class="absolute inset-0 flex items-center justify-center opacity-0">
        <svg viewBox="0 0 200 360" class="h-[55vh] w-auto" fill="#0a0103">
          <circle cx="100" cy="58" r="40" />
          <path d="M52 112 q48 -22 96 0 l14 150 q-62 26 -124 0 z" />
          <rect x="68" y="250" width="26" height="104" rx="6" />
          <rect x="106" y="250" width="26" height="104" rx="6" />
        </svg>
      </div>
      <div id="egg-teeth" class="absolute inset-0">
        <svg viewBox="0 0 1000 1000" preserveAspectRatio="xMidYMid slice" class="w-full h-full">
          <polygon fill="#f4ece0" points="0,0 1000,0 1000,130 925,300 855,160 780,310 705,165 630,315 555,160 480,310 405,170 330,315 255,160 180,305 105,165 35,300 0,130" />
          <polygon fill="#f4ece0" points="0,1000 1000,1000 1000,870 925,700 855,840 780,690 705,835 630,685 555,840 480,690 405,830 330,685 255,840 180,695 105,835 35,700 0,870" />
        </svg>
      </div>
    </div>

    <!-- Netflix-style subtitle (variant 2 interaction): bottom-center, over
         everything including the content card. -->
    <div
      id="egg-subtitle"
      aria-hidden="true"
      class="fixed inset-x-0 bottom-[8%] z-[60] flex justify-center px-4 pointer-events-none"
    >
      <span class="egg-sub-text opacity-0 bg-black text-white px-3 py-1 rounded-[3px] text-xl md:text-3xl font-medium leading-snug">お前は違う</span>
    </div>

    <div class="relative z-10 min-h-screen flex items-center justify-center p-4 md:p-8">
      <div
        class="grid grid-cols-1 lg:grid-cols-12 max-w-5xl w-full bg-darkblue-100 rounded-3xl overflow-hidden shadow-2xl lg:h-[80vh]"
      >
        <!-- Left Column: Main Content -->
        <main
          class="lg:col-span-9 p-8 md:p-12 flex flex-col gap-12 overflow-y-scroll custom-scrollbar"
        >
          <!-- Profile / Intro -->
          <slot />
        </main>

        <!-- Right Column: Sidebar -->
        <aside
          class="lg:col-span-3 bg-darkblue-200 p-8 md:p-12 flex flex-col justify-between border-l border-white/5"
        >
          <!-- Navigation -->
          <div class="space-y-3">
            <h3 class="text-sm font-bold text-primary-opaque">things</h3>
            <nav>
              <ul class="space-y-2">
                <li>
                  <a
                    href="/"
                    class={`flex items-center gap-3  transition-colors duration-200 ${isHome ? "text-primary" : "text-primary-opaque hover:text-primary hover:text-accent-blue"}`}
                  >
                    <img src="/icons/me.png" alt="" class="w-5 h-5 shrink-0" />
                    me
                  </a>
                </li>
                <li>
                  <a
                    href="/projects"
                    class={`flex items-center gap-3  transition-colors duration-200 ${isProjects ? "text-primary" : "text-primary-opaque hover:text-primary hover:text-accent-blue"}`}
                  >
                    <img src="/icons/projects.png" alt="" class="w-5 h-5 shrink-0" />
                    projects
                  </a>
                </li>
                <li>
                  <a
                    href="/listen"
                    class={`flex items-center gap-3  transition-colors duration-200 ${isListen ? "text-primary" : "text-primary-opaque hover:text-primary hover:text-accent-blue"}`}
                  >
                    <img src="/icons/listen.png" alt="" class="w-5 h-5 shrink-0" />
                    listen
                  </a>
                </li>
                <li>
                  <a
                    href="/watch"
                    class={`flex items-center gap-3  transition-colors duration-200 ${isWatch ? "text-primary" : "text-primary-opaque hover:text-primary hover:text-accent-blue"}`}
                  >
                    <img src="/icons/watch.png" alt="" class="w-5 h-5 shrink-0" />
                    watch/read
                  </a>
                </li>
              </ul>
            </nav>
          </div>

          <!-- Footer Info -->
          <div class="flex flex-col gap-10 mt-12 lg:mt-auto">            
            <div class="space-y-3">
              <h3 class="text-sm font-bold text-primary-opaque">social</h3>
              <div class="grid grid-cols-2 gap-6 text-primary">
                {
                  Array.from({
                    length: Math.ceil(userConfig.socials.length / 4),
                  })
                    .slice(0, 2) // ensure max 2 columns
                    .map((_, colIndex) => {
                      const start = colIndex * 4;
                      const items = userConfig.socials.slice(start, start + 4);

                      return (
                        <ul class="flex flex-col gap-2">
                          {items.map((social) => (
                            <li>
                              <a
                                href={social.url}
                                target="_blank"
                                class="italic transition-colors duration-200"
                              >
                                {social.name}
                              </a>
                            </li>
                          ))}
                        </ul>
                      );
                    })
                }
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>

    <style>
      /* Dorohedoro — the wet red dark of Kaiman's throat. */
      .egg-throat {
        background: radial-gradient(circle at 50% 52%, #6a0d0d 0%, #3a0707 38%, #160203 72%, #0a0103 100%);
      }
      /* Classic subtitle: white text on an opaque black box. */
      .egg-sub-text { letter-spacing: 0.03em; }
    </style>

    <script>
      // Easter egg (Dorohedoro) — clicking the home avatar ([data-egg-trigger])
      // travels into Kaiman's mouth to reveal Risu behind the card, then drops a
      // timed Netflix-style subtitle.
      (() => {
        const trigger = document.querySelector<HTMLElement>("[data-egg-trigger]");
        const dBg = document.getElementById("egg-bg-doro");
        const teeth = document.getElementById("egg-teeth");
        const risu = document.getElementById("egg-risu");
        const sub = document.getElementById("egg-subtitle");
        // The avatar only exists on home; bail elsewhere or if anything's missing.
        if (!trigger || !dBg || !teeth || !risu || !sub) return;

        let playing = false;

        function play() {
          dBg!.style.opacity = "1";
          // travel forward: the front teeth blow past the camera...
          teeth!.animate(
            [
              { transform: "scale(1)", opacity: 1 },
              { transform: "scale(2.6)", opacity: 0 },
            ],
            { duration: 1500, easing: "cubic-bezier(.45,0,.55,1)", fill: "forwards" },
          );
          // ...revealing Risu deeper in the throat
          risu!.animate(
            [
              { transform: "scale(.7)", opacity: 0 },
              { transform: "scale(1)", opacity: 1 },
            ],
            { duration: 1200, delay: 600, easing: "ease-out", fill: "forwards" },
          );
          // then the subtitle appears over everything, holds, and fades —
          // timed like a real subtitle line, not permanent
          setTimeout(() => {
            const line = sub!.querySelector<HTMLElement>(".egg-sub-text");
            if (line) {
              line.animate(
                [
                  { transform: "translateY(8px)", opacity: 0 },
                  { transform: "translateY(0)", opacity: 1 },
                ],
                { duration: 320, easing: "ease-out", fill: "forwards" },
              );
              setTimeout(() => {
                line.animate([{ opacity: 1 }, { opacity: 0 }], {
                  duration: 400,
                  easing: "ease-in",
                  fill: "forwards",
                });
              }, 3000);
            }
            playing = false;
          }, 1450);
        }

        trigger.style.cursor = "pointer";
        trigger.addEventListener("click", (e) => {
          e.preventDefault();
          if (playing) return;
          playing = true;
          play();
        });
      })();      
    </script>
  </body>
</html>
